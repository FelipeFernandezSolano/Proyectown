VITE_API_URL=http://localhost:8080/api
# El login con Google (boton "Iniciar sesion con Google" en Login/Registro) ya no necesita
# ninguna variable en el frontend: el Client ID y Client Secret viven solo en el backend
# (GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET), y el boton simplemente enlaza a
# VITE_API_URL + /auth/google/login.
